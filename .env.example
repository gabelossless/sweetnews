# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Firebase Configuration
VITE_FIREBASE_API_KEY="YOUR_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="YOUR_AUTH_DOMAIN"
VITE_FIREBASE_PROJECT_ID="YOUR_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="YOUR_STORAGE_BUCKET"
VITE_FIREBASE_MESSAGING_SENDER_ID="YOUR_MESSAGING_SENDER_ID"
VITE_FIREBASE_APP_ID="YOUR_APP_ID"

# Stripe Configuration
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_YOUR_STRIPE_PUBLISHABLE_KEY"
STRIPE_SECRET_KEY="sk_test_YOUR_STRIPE_SECRET_KEY"   # server-only, never use VITE_ prefix

# Resend (owner email notifications)
RESEND_API_KEY="re_YOUR_RESEND_API_KEY"

# Firebase Cloud Messaging (customer push notifications)
VITE_FIREBASE_VAPID_KEY="BA..."   # Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
FIREBASE_SERVICE_ACCOUNT_JSON=""  # base64-encoded service account JSON — firebase console → service accounts → generate key → base64

# Self-dispatch (optional: owner's driver account UID for one-click assign)
VITE_OWNER_DRIVER_UID=""          # UID of owner's driver_active account

# Fleet driver earnings display (shown in History tab)
VITE_DRIVER_PAYOUT_PER_DELIVERY="3.50"  # Flat payout shown per completed delivery
